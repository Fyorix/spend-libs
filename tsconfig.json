{
  "compilerOptions": {
    "declaration": true,
    "outDir": "dist",
    "target": "ES2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["jest", "node", "reflect-metadata"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@clement.pasteau/*": ["packages/*/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*"],
}
