{
  "name": "@clement.pasteau/contracts",
  "version": "1.2.0",
  "description": "Fyorix Spend App Contracts",
  "license": "UNLICENSED",
  "type": "module",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "proto"
  ],
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "build": "yarn fix-esm && tsc -p tsconfig.json",
    "fix-esm": "node scripts/fix-esm.mjs",
    "lint": "eslint src/",
    "gen-proto": "protoc --plugin=protoc-gen-ts_proto=$(yarn bin protoc-gen-ts_proto) --ts_proto_out=src --ts_proto_opt=nestJs=true,fileSuffix=.pb,esModuleInterop=true,importSuffix=.js --proto_path=proto proto/**/*.proto",
    "test": "echo \"No tests yet\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/microservices": "^11.1.17",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-proto": "^2.11.5",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.57.1"
  },
  "peerDependencies": {
    "@nestjs/microservices": "^11.0.0",
    "rxjs": "^7.0.0"
  },
  "dependencies": {
    "protobufjs": "7.5.3"
  }
}
